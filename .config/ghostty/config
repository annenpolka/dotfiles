theme      = tokyonight
font-family = "SF Mono"
font-size   = 15
font-feature = -dlig
font-feature = -liga
font-feature = -calt

background-opacity = 0.99
background-blur    = 20
unfocused-split-opacity = 0.6

fullscreen = true
window-inherit-working-directory = true

keybind = super+slash=goto_split:previous
keybind = super+backslash=goto_split:next
