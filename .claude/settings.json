{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "env": {
    "DISABLE_MICROCOMPACT": "true",
    "CLAUDE_CODE_NEW_INIT": "1",
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "CLAUDE_CODE_NO_FLICKER": "1"
  },
  "permissions": {
    "defaultMode": "auto"
  },
  "hooks": {
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "afplay /System/Library/Sounds/Glass.aiff"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "sh /Users/annenpolka/.claude/statusline-command.sh"
  },
  "enabledPlugins": {
    "plugin-dev@claude-plugins-official": true,
    "rust-analyzer-lsp@claude-plugins-official": true,
    "feature-dev@claude-plugins-official": true,
    "swift-lsp@claude-plugins-official": true,
    "codex@openai-codex": true,
    "decision-forensics@annenpolka-skills": true,
    "revdiff@revdiff": true,
    "skill-creator@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {
    "openai-codex": {
      "source": {
        "source": "github",
        "repo": "openai/codex-plugin-cc"
      }
    },
    "annenpolka-skills": {
      "source": {
        "source": "directory",
        "path": "/Users/annenpolka/ghq/github.com/annenpolka/skills"
      },
      "autoUpdate": true
    },
    "revdiff": {
      "source": {
        "source": "github",
        "repo": "umputun/revdiff"
      }
    }
  },
  "language": "Japanese",
  "effortLevel": "xhigh",
  "tui": "default",
  "showThinkingSummaries": true,
  "skipDangerousModePermissionPrompt": true,
  "skipAutoPermissionPrompt": true,
  "voiceEnabled": true,
  "feedbackSurveyState": {
    "lastShownTime": 1754041917747
  },
  "thinking": {
    "type": "adaptive",
    "display": "summarized"
  },
  "output_config": {
    "effort": "max"
  }
}
