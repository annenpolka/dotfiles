# dotfiles依存パッケージ（.zshrcや.config/から参照されるツール）
tap "morantron/tmux-fingers" # tmux-fingers formula

brew "tmux"         # ターミナルマルチプレクサ (.config/tmux)
brew "neovim"       # 標準エディタ (.zshrc EDITOR, .config/tmux extrakto)
brew "python@3.13"  # python3 runtime (.config/tmux extrakto)
brew "sheldon"      # zshプラグインマネージャ (.zshrc)
brew "starship"     # クロスシェルプロンプト (sheldon/plugins.toml)
brew "eza"          # モダンls (.zshrc aliases)
brew "fzf"          # ファジーファインダー (.zshrc ghq-fzf, .config/tmux)
brew "ghq"          # リポジトリ管理 (.zshrc ghq-fzf)
brew "macism"       # macOS IME切り替え (.config/tmux prefix)
brew "tmux-fingers" # tmux visible token hints (.config/tmux)
brew "zoxide"       # スマートcd (.zshrc)
brew "direnv"       # ディレクトリ環境変数 (.zshrc)
brew "yazi"         # ターミナルファイルマネージャ (.zshrc)
brew "lazygit"      # ターミナルGit UI (.zshrc alias, .config/lazygit)
